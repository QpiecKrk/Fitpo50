# === Security Headers ===
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
  Header always set X-Robots-Tag "noindex, nofollow"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://api.fontshare.com https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self';"
</IfModule>

# === Block direct access to PHP files in actions/ ===
<FilesMatch "^(config|auth)\.php$">
  Order allow,deny
  Deny from all
</FilesMatch>

# === Redirect root to login ===
DirectoryIndex login.php index.php

# === No directory listing ===
Options -Indexes
